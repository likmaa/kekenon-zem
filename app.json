{
  "expo": {
    "name": "Kêkênon Zem",
    "slug": "kekenon-zem",
    "version": "2.2.2",
    "orientation": "default",
    "icon": "./assets/images/app-icon.png",
    "scheme": "kekenondriver",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": false,
    "splash": {
      "image": "./assets/images/LOGO_OR.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "buildNumber": "9",
      "supportsTablet": true,
      "googleServicesFile": "./GoogleService-Info.plist",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false,
        "NSLocationWhenInUseUsageDescription": "Nous avons besoin de votre position pour vous localiser sur la carte et suivre vos trajets.",
        "NSLocationAlwaysUsageDescription": "L'application a besoin de votre position en arrière-plan pour assurer le suivi de votre trajet en tant que chauffeur, même quand l'écran est éteint.",
        "NSLocationAlwaysAndWhenInUseUsageDescription": "L'application a besoin de votre position en arrière-plan pour assurer le suivi de votre trajet.",
        "UIBackgroundModes": [
          "location",
          "fetch",
          "remote-notification"
        ],
        "LSApplicationQueriesSchemes": [
          "comgooglemaps",
          "googlemaps",
          "waze"
        ]
      },
      "bundleIdentifier": "com.kekenon.driver"
    },
    "android": {
      "googleServicesFile": "./google-services.json",
      "versionCode": 9,
      "package": "com.kekenon.driver",
      "permissions": [
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_BACKGROUND_LOCATION",
        "android.permission.FOREGROUND_SERVICE",
        "android.permission.FOREGROUND_SERVICE_LOCATION",
        "android.permission.CALL_PHONE"
      ],
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "#3650D0"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-task-manager",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/LOGO_OR.png",
          "imageWidth": 150,
          "resizeMode": "contain",
          "backgroundColor": "#ffffff",
          "dark": {
            "backgroundColor": "#000000"
          }
        }
      ],
      "expo-location",
      "expo-font",
      "expo-notifications",
      [
        "expo-build-properties",
        {
          "android": {
            "usesCleartextTraffic": false
          }
        }
      ]
    ],
    "extra": {
      "mapboxToken": "${EXPO_PUBLIC_MAPBOX_TOKEN}",
      "router": {},
      "eas": {
        "projectId": "596f8ecc-d83f-407a-91c2-6175f95b441c"
      }
    },
    "owner": "kekenon",
    "runtimeVersion": "2.1.0"
  }
}