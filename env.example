# API Configuration
EXPO_PUBLIC_API_URL=https://api.kekenon.com/api

# Maps (pk.* = runtime ; sk.* = téléchargement SDK uniquement, ne jamais committer)
EXPO_PUBLIC_GOOGLE_MAPS_API_KEY=YOUR_GOOGLE_MAPS_API_KEY
EXPO_PUBLIC_MAPBOX_TOKEN=YOUR_MAPBOX_PUBLIC_TOKEN
# EAS Build (cloud) : ne pas mettre EXPO_PUBLIC_MAPBOX_TOKEN dans eas.json (push GitHub bloqué).
# eas secret:create --scope project --name EXPO_PUBLIC_MAPBOX_TOKEN --value "pk...." --type string
# Secret Mapbox (Downloads: account.mapbox.com) — requis pour prebuild/EAS Build ; EAS: eas secret:create --name MAPBOX_DOWNLOAD_TOKEN
MAPBOX_DOWNLOAD_TOKEN=YOUR_MAPBOX_SECRET_DOWNLOAD_TOKEN

# Pusher/Soketi Configuration
EXPO_PUBLIC_PUSHER_KEY=your-pusher-key
EXPO_PUBLIC_PUSHER_HOST=ws.kekenon.com
EXPO_PUBLIC_PUSHER_PORT=443
EXPO_PUBLIC_PUSHER_CLUSTER=mt1
EXPO_PUBLIC_PUSHER_TLS=true
